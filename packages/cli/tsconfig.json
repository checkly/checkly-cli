{
  "compilerOptions": {
    "incremental": true,
    "declaration": true,
    "importHelpers": false,
    "module": "nodenext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "es2022",
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/**/__tests__",
    "src/ai-context/onboarding-boilerplate",
    "e2e"
  ]
}