{
  "name": "tsconfig-extends-workspace",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "tsconfig-extends-workspace",
      "version": "1.0.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "packages/config": {
      "name": "@scope/config",
      "version": "1.0.0"
    },
    "node_modules/@scope/config": {
      "resolved": "packages/config",
      "link": true
    }
  }
}
